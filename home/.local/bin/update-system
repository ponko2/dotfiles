#!/usr/bin/env bash

set -euo pipefail

if command -v darwin-rebuild >/dev/null; then
  # Nix
  NIX_CONFIG="access-tokens = github.com=$(gh auth token)" nix flake update --flake ~/dotfiles
  nh darwin switch
  nh clean all --keep 3 --keep-since 4d
else
  # Homebrew
  brew update --auto-update
  brew upgrade --fetch-HEAD
fi

# Yazi
ya pkg upgrade

# Sheldon
sheldon lock --update

# Neovim
git -C ~/.local/share/nvim/lazy/vimdoc-ja restore doc/tags-ja
nvim --headless "+Lazy! update" +qa
