{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "library": [
      "${env:VIMRUNTIME}/lua",
      "${3rd}/busted/library",
      "${3rd}/luv/library",
      "${env:XDG_DATA_HOME}/nvim/lazy/dial.nvim/lua",
      "${env:XDG_DATA_HOME}/nvim/lazy/gitsigns.nvim/lua",
      "${env:XDG_DATA_HOME}/nvim/lazy/lazy.nvim/lua",
      "${env:XDG_DATA_HOME}/nvim/lazy/oil.nvim/lua",
      "${env:XDG_DATA_HOME}/nvim/lazy/telescope.nvim/lua",
      "${env:XDG_DATA_HOME}/nvim/lazy/yazi.nvim/lua"
    ],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": ["vim"],
    "groupFileStatus": {
      "strict": "Opened",
      "strong": "Opened"
    },
    "groupSeverity": {
      "strong": "Warning",
      "strict": "Warning"
    },
    "unusedLocalExclude": ["_*"]
  },
  "Lua": {
    "format": {
      "enable": false
    }
  }
}
